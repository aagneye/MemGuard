# ── LLM Provider ────────────────────────────────────────────────────────────
# Set to "qwen" for production, "ollama" for local dev without API costs.
LLM_PROVIDER=ollama

OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:7b

# Qwen Cloud (DashScope) — required when LLM_PROVIDER=qwen
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
DASHSCOPE_API_KEY=
# Spec-named aliases (these take priority when set)
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_API_KEY=
QWEN_CHAT_MODEL=qwen-plus

# ── Memory & Session ─────────────────────────────────────────────────────────
SIMILARITY_THRESHOLD=0.8
SESSION_TTL_SECONDS=1800

# Decay time scaling: 1.0 = real time, 1440 = 1 minute = 1 day (demo mode)
DEMO_TIME_SCALE=1.0

# Rate limiting: max requests per IP per minute on the public demo
RATE_LIMIT_RPM=60

# ── Database (for future Postgres + pgvector migration) ──────────────────────
DATABASE_URL=postgresql+asyncpg://memguard:memguard@localhost:5432/memguard
REDIS_URL=redis://localhost:6379/0

# ── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE=http://localhost:8000

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins for production
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ── Google OAuth (optional — not required for public demo) ──────────────────
GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# ── Backend server ───────────────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
